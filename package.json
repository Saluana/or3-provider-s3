{
    "name": "or3-provider-s3",
    "version": "0.0.1",
    "description": "S3-compatible storage provider for OR3 Chat — server-signed presigned URLs via StorageGatewayAdapter.",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/types.d.mts",
            "import": "./dist/module.mjs"
        },
        "./nuxt": {
            "types": "./dist/types.d.mts",
            "import": "./dist/module.mjs"
        }
    },
    "main": "./dist/module.mjs",
    "types": "./dist/types.d.mts",
    "files": [
        "dist"
    ],
    "scripts": {
        "prepack": "bun run build",
        "build": "nuxt-module-build build",
        "lint": "eslint . --max-warnings=0",
        "type-check": "tsc --noEmit",
        "test": "vitest run"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.888.0",
        "@aws-sdk/s3-request-presigner": "^3.888.0"
    },
    "peerDependencies": {
        "@nuxt/kit": "^3.0.0 || ^4.0.0",
        "nuxt": "^3.0.0 || ^4.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@nuxt/module-builder": "^1.0.2",
        "@types/node": "^25.2.2",
        "eslint": "^9.39.1",
        "h3": "^1.15.4",
        "pathe": "^2.0.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.2",
        "vitest": "^4.0.18"
    }
}
